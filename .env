# ============================================================================
# VoiceAI Orchestrator — Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your deployment:
#
#   cp .env.example .env
#
# All settings have sensible defaults — the platform works out of the box
# with local providers only (Whisper + Ollama + Kokoro).
# ============================================================================

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=VoiceAI Orchestrator
APP_VERSION=0.1.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://voiceai:voiceai@localhost:5432/voiceai

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# REQUIRED for production. Generate with: openssl rand -base64 32
AUTH_SECRET=XZd4mkd4a6Q3eFNTKkhLR4tktGRVJb2wI1_LErcHh9I
AUTH_URL=http://localhost:3000

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SEC=60

# ── Redis (optional) ────────────────────────────────────────────────────────
REDIS_URL=

# ── Active Providers ─────────────────────────────────────────────────────────
STT_PROVIDER=whisper
LLM_PROVIDER=ollama
TTS_PROVIDER=kokoro

# ── STT: Whisper (local, default) ────────────────────────────────────────────
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_MODEL_SIZE=auto
WHISPER_CPU_THREADS=4

# ── STT: Deepgram (cloud, optional) ──────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── LLM: Ollama (local, default) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── LLM: OpenAI (cloud, optional) ────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── LLM: Gemini (cloud, optional) ────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── LLM: OpenRouter (cloud, optional) ────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen-2.5-72b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── LLM: Common ──────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ── TTS: Kokoro (local, default) ─────────────────────────────────────────────
KOKORO_MODEL_PATH=
KOKORO_VOICE=default

# ── TTS: OpenVoice (local, voice cloning) ────────────────────────────────────
OPENVOICE_MODEL_PATH=

# ── TTS: XTTS-v2 (local, multi-language) ─────────────────────────────────────
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_DEVICE=auto
XTTS_SPEAKER_SAMPLE=

# ── TTS: ElevenLabs (cloud, optional) ────────────────────────────────────────
ELEVENLABS_API_KEY=

# ── TTS: Common ──────────────────────────────────────────────────────────────
DEFAULT_VOICE_ID=af_bella
DEFAULT_LANGUAGE=en
DEFAULT_SPEAKING_RATE=1.0
DEFAULT_PITCH=0.0

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_FOLDER=audio
SAMPLE_RATE=16000
NUM_CHANNELS=1

# ── GPU / Hardware ───────────────────────────────────────────────────────────
TORCH_DEVICE=auto
EMBEDDING_DEVICE=auto
CUDA_VISIBLE_DEVICES=

# ── LiveKit (Realtime Voice Transport) ───────────────────────────────────────
LIVEKIT_ENABLED=false
LIVEKIT_SERVER_URL=ws://localhost:7880
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_ROOM_PREFIX=voiceai-
LIVEKIT_AGENT_NAME=VoiceAI Agent
LIVEKIT_WORKER_PORT=8001
LIVEKIT_WORKER_LOG_LEVEL=info

# ── SIP / Telephony (Twilio -> LiveKit -> PSTN) ──────────────────────────────
SIP_ENABLED=false
SIP_SERVER_ADDRESS=0.0.0.0
SIP_PORT=5060
SIP_DISPATCH_DESTINATION=twilio-sip-trunk
SIP_ROOM_PREFIX=sip-
SIP_TRUNK_HOST=

# ── Embeddings (RAG + Memory) ────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Advanced Conversation Features ───────────────────────────────────────────
ADAPTIVE_CONVERSATION_ENABLED=true
INTERRUPT_DETECTION_ENABLED=true
ADVANCED_STATE_ENGINE_ENABLED=true
ADAPTIVE_PLAYBACK_ENABLED=true
SEMANTIC_ANALYSIS_ENABLED=false
INTERRUPT_VOLUME_THRESHOLD=0.15

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000

# ── Subscription Enforcement (SaaS — opt-in) ─────────────────────────────────
ENFORCE_SUBSCRIPTIONS=false
